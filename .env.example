# Salin file ini ke .env dan isi dengan nilai yang benar
# cp .env.example .env

# TikTok username pemilik live (tanpa @)
TIKTOK_USERNAME=username_tiktok_kamu

# TikTok session ID dari browser (WAJIB jika deploy di server cloud)
# Cara ambil: Login TikTok di browser → F12 → Application → Cookies → tiktok.com → cari "sessionid"
TIKTOK_SESSION_ID=

# Groq API Key (https://console.groq.com/keys)
GROQ_API_KEY=gsk_...

# Nama persona bot (akan dipakai di komentar)
BOT_PERSONA_NAME=Andi

# Bahasa komentar: id (Indonesia) atau en (English)
BOT_LANGUAGE=id

# Interval minimum antar komentar (detik) - jangan terlalu cepat biar ga kena ban
COMMENT_MIN_INTERVAL=30

# Interval maksimum antar komentar (detik)
COMMENT_MAX_INTERVAL=90

# Apakah bot boleh balas komentar orang lain? true/false
REPLY_TO_COMMENTS=true

# Max berapa komentar orang yang dibalas per menit
MAX_REPLIES_PER_MINUTE=2
